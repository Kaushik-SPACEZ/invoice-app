### BizSync API — Full Production Test Suite
### Base URL: https://invoice.kynetropo.com/api
### Run with: REST Client (VS Code) or httpyac
###
### Variables are set via responses — run in ORDER, top to bottom
### ==============================================================

@base = https://invoice.kynetropo.com/api
@contentJson = Content-Type: application/json
@accept = Accept: application/json

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SECTION 1 — AUTHENTICATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

### 1.1 [HAPPY] Login as Kaushik → get JWT
# @name loginKaushik
POST {{base}}/auth/login
{{contentJson}}
{{accept}}

{
  "email": "kaushik@kynetropo.com",
  "password": "Kynetropo@2024"
}

###
@tokenK = {{loginKaushik.response.body.data.access_token}}

### 1.2 [HAPPY] Login as Raj → get JWT
# @name loginRaj
POST {{base}}/auth/login
{{contentJson}}
{{accept}}

{
  "email": "raj@rkelectronics.com",
  "password": "password123"
}

###
@tokenR = {{loginRaj.response.body.data.access_token}}

### 1.3 [HAPPY] Get current user (Kaushik)
GET {{base}}/auth/me
Authorization: Bearer {{tokenK}}
{{accept}}

### 1.4 [SAD] Wrong password → 401
POST {{base}}/auth/login
{{contentJson}}
{{accept}}

{
  "email": "kaushik@kynetropo.com",
  "password": "wrongpassword"
}

### 1.5 [SAD] Unknown email → 401
POST {{base}}/auth/login
{{contentJson}}
{{accept}}

{
  "email": "nobody@nowhere.com",
  "password": "password123"
}

### 1.6 [EDGE] Missing fields → 422
POST {{base}}/auth/login
{{contentJson}}
{{accept}}

{
  "email": "kaushik@kynetropo.com"
}

### 1.7 [EDGE] No token → 401
GET {{base}}/auth/me
{{accept}}

### 1.8 [EDGE] Expired/garbage token → 401
GET {{base}}/auth/me
Authorization: Bearer garbage.token.here
{{accept}}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SECTION 2 — INVENTORY / PRODUCTS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

### 2.1 [HAPPY] List all products (Kaushik)
GET {{base}}/products
Authorization: Bearer {{tokenK}}
{{accept}}

### 2.2 [HAPPY] Create product
# @name createProduct
POST {{base}}/products
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "sku": "TEST-SKU-001",
  "name": "Test Abacus Kit",
  "category": "Toys",
  "hsn_code": "9503",
  "unit": "pcs",
  "cost_price": 150,
  "selling_price": 299,
  "current_stock": 50,
  "min_stock_level": 5
}

###
@productId = {{createProduct.response.body.data.id}}

### 2.3 [HAPPY] Get single product
GET {{base}}/products/{{productId}}
Authorization: Bearer {{tokenK}}
{{accept}}

### 2.4 [SAD] Duplicate SKU → 422
POST {{base}}/products
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "sku": "TEST-SKU-001",
  "name": "Another Product",
  "selling_price": 100,
  "current_stock": 10
}

### 2.5 [SAD] Missing required fields → 422
POST {{base}}/products
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "category": "Toys"
}

### 2.6 [EDGE] Stock filter — low stock
GET {{base}}/products?stock_level=low
Authorization: Bearer {{tokenK}}
{{accept}}

### 2.7 [EDGE] Stock filter — zero stock
GET {{base}}/products?stock_level=zero
Authorization: Bearer {{tokenK}}
{{accept}}

### 2.8 [EDGE] Category filter
GET {{base}}/products?category=Toys
Authorization: Bearer {{tokenK}}
{{accept}}

### 2.9 [EDGE] Search by SKU
GET {{base}}/products?search=TEST-SKU
Authorization: Bearer {{tokenK}}
{{accept}}

### 2.10 [EDGE] Low stock endpoint
GET {{base}}/products/low-stock
Authorization: Bearer {{tokenK}}
{{accept}}

### 2.11 [EDGE] Raj cannot see Kaushik's products
GET {{base}}/products/{{productId}}
Authorization: Bearer {{tokenR}}
{{accept}}

### 2.12 [HAPPY] Update product (set low stock to trigger alert)
PUT {{base}}/products/{{productId}}
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "current_stock": 3,
  "min_stock_level": 5
}

### 2.13 Verify low-stock now appears
GET {{base}}/products/low-stock
Authorization: Bearer {{tokenK}}
{{accept}}

### 2.14 Restore stock to 50
PUT {{base}}/products/{{productId}}
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "current_stock": 50
}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SECTION 3 — PRODUCT MAPPINGS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

### 3.1 [HAPPY] List all mappings
GET {{base}}/product-mappings
Authorization: Bearer {{tokenK}}
{{accept}}

### 3.2 [HAPPY] Create mapping: "Test Abacus Kit" → TEST-SKU-001
# @name createMapping
POST {{base}}/product-mappings
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "invoice_product_name": "15 ROD MULTICOLOR ABACUS KIT",
  "items": [
    {
      "product_id": {{productId}},
      "quantity": 1
    }
  ]
}

###
@mappingId = {{createMapping.response.body.data.id}}

### 3.3 [HAPPY] Check — mapped name returns mapping
POST {{base}}/product-mappings/check
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "product_names": ["15 ROD MULTICOLOR ABACUS KIT"]
}

### 3.4 [EDGE] Normalized name match (case-insensitive, extra spaces)
POST {{base}}/product-mappings/check
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "product_names": ["  15 rod multicolor abacus kit  "]
}

### 3.5 [HAPPY] Check — unmapped name returns null
POST {{base}}/product-mappings/check
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "product_names": ["COMPLETELY UNKNOWN PRODUCT XYZ"]
}

### 3.6 [EDGE] Mixed: one mapped, one unmapped
POST {{base}}/product-mappings/check
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "product_names": [
    "15 ROD MULTICOLOR ABACUS KIT",
    "COMPLETELY UNKNOWN PRODUCT XYZ"
  ]
}

### 3.7 [SAD] Duplicate mapping → 422
POST {{base}}/product-mappings
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "invoice_product_name": "15 ROD MULTICOLOR ABACUS KIT",
  "items": [
    {
      "product_id": {{productId}},
      "quantity": 1
    }
  ]
}

### 3.8 [SAD] Missing product_id → 422
POST {{base}}/product-mappings
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "invoice_product_name": "Some Product",
  "items": [
    {
      "quantity": 1
    }
  ]
}

### 3.9 [SAD] Non-existent product_id → 422
POST {{base}}/product-mappings
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "invoice_product_name": "Another Product Name",
  "items": [
    {
      "product_id": 999999,
      "quantity": 1
    }
  ]
}

### 3.10 [HAPPY] Update mapping
PUT {{base}}/product-mappings/{{mappingId}}
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "items": [
    {
      "product_id": {{productId}},
      "quantity": 2
    }
  ]
}

### 3.11 Verify items updated (quantity = 2)
GET {{base}}/product-mappings/{{mappingId}}
Authorization: Bearer {{tokenK}}
{{accept}}


