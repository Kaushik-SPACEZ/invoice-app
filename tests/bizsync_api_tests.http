# SECTION 13 — REPORTS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

### 13.1 [HAPPY] Generate sales report
# @name genSalesReport
POST {{base}}/reports/generate
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "type": "sales",
  "from_date": "2026-01-01",
  "to_date": "2026-12-31",
  "format": "excel",
  "fields": ["date", "order_number", "marketplace", "revenue", "tax", "net_revenue"]
}

###
@reportId = {{genSalesReport.response.body.data.report_id}}

### 13.2 Download report (binary — check 200 response)
GET {{base}}/reports/{{reportId}}/download
Authorization: Bearer {{tokenK}}

### 13.3 [HAPPY] Generate inventory report
POST {{base}}/reports/generate
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "type": "inventory",
  "from_date": "2026-01-01",
  "to_date": "2026-12-31",
  "format": "excel",
  "fields": ["sku", "name", "category", "current_stock", "cost_price", "selling_price"]
}

### 13.4 [HAPPY] Generate GST report
POST {{base}}/reports/generate
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "type": "gst",
  "from_date": "2026-04-01",
  "to_date": "2026-07-09",
  "format": "excel",
  "fields": ["period", "output_gst", "input_gst", "net_gst", "cgst", "sgst", "igst"]
}

