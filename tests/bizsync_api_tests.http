# SECTION 5 — INVOICE APPROVAL CASCADE TEST
# This section manually simulates the approval with synthetic data
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

### 5.1 Check stock BEFORE (should be 50 after our restore above)
GET {{base}}/products/{{productId}}
Authorization: Bearer {{tokenK}}
{{accept}}

### 5.2 Create a test invoice manually (set to review status for approval)
# @name createTestInvoice
POST {{base}}/invoices
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "invoice_number": "TEST-INV-APPROVE-001",
  "invoice_date": "2026-07-09",
  "vendor_name": "Test Vendor",
  "marketplace": "amazon",
  "processing_status": "review",
  "total_amount": 299,
  "tax_amount": 27.18,
  "subtotal": 271.82
}

###
@testInvoiceId = {{createTestInvoice.response.body.data.id}}

### 5.3 [HAPPY] Approve the invoice with validated_data + line_items
PUT {{base}}/invoices/{{testInvoiceId}}/approve
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "validated_data": {
    "invoice_number": "TEST-INV-APPROVE-001",
    "invoice_date": "2026-07-09",
    "vendor_name": "Test Vendor",
    "vendor_gstin": "27AABCU9603R1ZX",
    "customer_name": "Test Customer",
    "customer_gstin": "",
    "subtotal": 271.82,
    "tax_amount": 27.18,
    "total_amount": 299,
    "line_items": [
      {
        "product_name": "15 ROD MULTICOLOR ABACUS KIT",
        "sku": "TEST-SKU-001",
        "quantity": 2,
        "unit_price": 149,
        "cgst_rate": 6,
        "sgst_rate": 6,
        "igst_rate": 0,
        "total_amount": 299
      }
    ]
  }
}

### 5.4 VERIFY: Stock should now be 48 (50 - 2 * qty_multiplier_2 = 46 OR 50 - 2 = 48)
### Our mapping has quantity=2, so 2 invoice units × 2 mapping multiplier = 4 deducted → 46
GET {{base}}/products/{{productId}}
Authorization: Bearer {{tokenK}}
{{accept}}

### 5.5 VERIFY: Sales order created
GET {{base}}/sales
Authorization: Bearer {{tokenK}}
{{accept}}

### 5.6 VERIFY: GST record created
GET {{base}}/gst/summary?year=2026
Authorization: Bearer {{tokenK}}
{{accept}}

### 5.7 VERIFY: Audit log has entry
GET {{base}}/audit-log
Authorization: Bearer {{tokenK}}
{{accept}}

### 5.8 VERIFY: Dashboard shows updated data
GET {{base}}/dashboard/summary
Authorization: Bearer {{tokenK}}
{{accept}}

### 5.9 [EDGE] Approve already-approved invoice (should handle gracefully)
PUT {{base}}/invoices/{{testInvoiceId}}/approve
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "validated_data": {}
}


