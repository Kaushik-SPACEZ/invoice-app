POST {{base}}/reports/generate
Authorization: Bearer {{tokenK}}
{{contentJson}}
{{accept}}

{
  "type": "nonexistent",
  "from_date": "2026-01-01",
  "to_date": "2026-12-31",
  "format": "excel"
}


